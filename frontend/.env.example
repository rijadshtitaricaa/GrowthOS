# Backend API URL
# Leave EMPTY during local development — Vite proxy handles routing to localhost:8000
# In production, set this to your deployed backend URL (e.g. https://api.growthos.com)
VITE_API_URL=

# Supabase — Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
